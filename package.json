{
  "name": "@fastgpt/official-plugins",
  "version": "1.0.0",
  "description": "Official plugins for FastGPT",
  "scripts": {
    "build": "turbo run build --continue=always --force --summarize",
    "build:cached": "turbo run build",
    "build:full-package": "pnpm run pack && mkdir -p dist && find packages -name '*.pkg' -exec cp {} dist \\; && zip -j dist/fastgpt-official-plugins-$(git describe --always).zip dist/*.pkg",
    "pack": "turbo run pack --continue=always --summarize",
    "type-check": "turbo run type-check --parallel",
    "biome-check": "turbo run biome-check --parallel",
    "postinstall": "lefthook install",
    "clean:node_modules": "tsx scripts/clean-node-modules.ts",
    "clean:dist": "tsx scripts/clean-dist.ts",
    "upload": "tsx --env-file-if-exists .env.local scripts/publish-to-marketplace.ts"
  },
  "keywords": [
    "fastgpt",
    "plugins",
    "official"
  ],
  "author": "FastGPT Team",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@fastgpt-plugin/cli": "catalog:",
    "@types/node": "catalog:",
    "lefthook": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  }
}
