{
  "name": "fastgpt-tools-arxiv",
  "version": "0.0.1",
  "description": "Provides ArXiv paper search functionalities, including keyword search, sorting, etc.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx @fastgpt-plugin/cli build --minify",
