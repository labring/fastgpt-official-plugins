    "pack": "npx @fastgpt-plugin/cli pack",
    "test": "vitest run"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "xml2js": "^0.4.23"
  },
  "devDependencies": {
    "@types/node-fetch": "latest",
    "@types/xml2js": "latest",
    "@fastgpt-plugin/cli": "catalog:",
